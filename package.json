{
  "name": "sysit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"a11y_autofocus:ignore\"",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"a11y_autofocus:ignore\" --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@mdi/js": "^7.4.47",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.6.0",
    "@vitest/browser-playwright": "^4.1.9",
    "@zerodevx/svelte-toast": "^0.9.6",
    "chota": "^0.9.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.1",
    "events": "^3.3.0",
    "freenit": "^0.2.4",
    "globals": "^17.6.0",
    "playwright": "^1.57.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-browser-svelte": "^2.0.1"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node"
  }
}
